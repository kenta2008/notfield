{
  "rules": {
    ".read": false,
    ".write": false,
    "gameRoom": {
      ".read": true,
      ".write": true,
      ".validate": "newData.hasChildren(['player1_hp', 'player2_hp', 'player1_mp', 'player2_mp', 'player1_def', 'player2_def', 'player1_hand', 'player2_hand', 'pending_attack', 'turn', 'round'])",

      "player1_hp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
      "player2_hp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
      "player1_mp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
      "player2_mp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
      "player1_def": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999" },
      "player2_def": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999" },
      "player1_pending_draws": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 20)" },
      "player2_pending_draws": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 20)" },
      "player1_hand_limit": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 8 && newData.val() <= 20)" },
      "player2_hand_limit": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 8 && newData.val() <= 20)" },
      "pending_attack": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999" },
      "round": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 999" },
      "reset_trigger": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },

      "turn": { ".validate": "newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2' || newData.val() == 'end')" },
      "winner": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2' || newData.val() == 'draw'))" },
      "player1_name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8)" },
      "player2_name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8)" },
      "player1_hand": {
        "$i": { ".validate": "$i.matches(/^(0|[1-9]|1[0-9])$/) && newData.isString() && newData.val().matches(/^[a-z0-9_]{1,40}$/)" }
      },
      "player2_hand": {
        "$i": { ".validate": "$i.matches(/^(0|[1-9]|1[0-9])$/) && newData.isString() && newData.val().matches(/^[a-z0-9_]{1,40}$/)" }
      },
      "player1_magic_hand": {
        ".validate": "!newData.exists() || true",
        "$i": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{1,40}$/)" }
      },
      "player2_magic_hand": {
        ".validate": "!newData.exists() || true",
        "$i": { ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{1,40}$/)" }
      },

      "player1_def_cards": {
        ".validate": "!newData.exists() || true",
        "$i": { "$other": { ".validate": true } }
      },
      "player2_def_cards": {
        ".validate": "!newData.exists() || true",
        "$i": { "$other": { ".validate": true } }
      },

      "selected_card": {
        ".validate": "!newData.exists() || newData.hasChildren(['player'])",
        "id": { ".validate": "!newData.exists() || newData.isNumber()" },
        "player": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "target": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "showOnTurn": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "type": { ".validate": "!newData.exists() || (newData.isString() && (newData.val().matches(/^[a-z_]{1,24}$/)))" },
        "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "label": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "element": { ".validate": "!newData.exists() || (newData.isString() && (newData.val().matches(/^[a-z_]{1,32}$/)))" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 240)" },
        "imgSrc": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "keep": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "randomPending": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "controlled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "boosts": {
          ".validate": "!newData.exists() || true",
          "$i": { "$other": { ".validate": true } }
        },
        "$other": { ".validate": false }
      },

      "attack_card": {
        ".validate": "!newData.exists() || newData.hasChildren(['player', 'target', 'value'])",
        "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "imgSrc": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "value": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
        "baseValue": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
        "multiplier": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 256)" },
        "element": { ".validate": "!newData.exists() || (newData.isString() && (newData.val().matches(/^[a-z_]{1,32}$/)))" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 260)" },
        "player": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "target": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "afterTurn": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "hit": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "hitRate": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1)" },
        "boostName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "boostLabel": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "boostDescription": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 240)" },
        "boostImgSrc": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "controlled": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "reflected": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "reflectionFrom": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "reflectionId": { ".validate": "!newData.exists() || newData.isNumber()" },
        "reflectionDepth": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 10)" },
        "relayRepeat": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 2)" },
        "repeatId": { ".validate": "!newData.exists() || newData.isNumber()" },
        "boosts": {
          ".validate": "!newData.exists() || true",
          "$i": { "$other": { ".validate": true } }
        },
        "$other": { ".validate": false }
      },

      "damage_result": {
        ".validate": "!newData.exists() || newData.hasChildren(['player'])",
        "id": { ".validate": "!newData.exists() || newData.isNumber()" },
        "player": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "attackPlayer": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "attackTarget": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "type": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'heal' || newData.val() == 'mpheal' || newData.val() == 'reflect'))" },
        "damage": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
        "amount": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 99)" },
        "rawDamage": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
        "message": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
        "instantDeath": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "knockout": { ".validate": "!newData.exists() || newData.isBoolean()" },
        "usedDefenseCards": {
          ".validate": "!newData.exists() || true",
          "$i": { "$other": { ".validate": true } }
        },
        "$other": { ".validate": false }
      },

      "hand_effect": {
        ".validate": "!newData.exists() || newData.hasChildren(['type', 'target'])",
        "id": { ".validate": "!newData.exists() || newData.isNumber()" },
        "type": { ".validate": "!newData.exists() || (newData.isString() && newData.val() == 'destroy_hand')" },
        "target": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "index": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 19)" },
        "cardKey": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)" },
        "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "cardType": { ".validate": "!newData.exists() || (newData.isString() && (newData.val().matches(/^[a-z_]{1,24}$/)))" },
        "element": { ".validate": "!newData.exists() || (newData.isString() && (newData.val().matches(/^[a-z_]{1,32}$/)))" },
        "value": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
        "reductionRate": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1)" },
        "description": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 240)" },
        "imgSrc": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "$other": { ".validate": false }
      },

      "control_effect": {
        ".validate": "!newData.exists() || newData.hasChildren(['target'])",
        "id": { ".validate": "!newData.exists() || newData.isNumber()" },
        "target": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "remaining": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 3)" },
        "actions": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 3)" },
        "$other": { ".validate": false }
      },

      "last_log": {
        ".validate": "!newData.exists() || newData.hasChildren(['player', 'message'])",
        "id": { ".validate": "!newData.exists() || newData.isNumber()" },
        "player": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'player1' || newData.val() == 'player2'))" },
        "message": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
        "$other": { ".validate": false }
      },

      "$other": { ".validate": false }
    }
  }
}
